# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://user:password@localhost:5432/mosaic?schema=public

# Redis connection string for shared rate-limit counters
REDIS_URL=redis://localhost:6379

# Secret for signing short-lived access JWTs (min 32 random chars)
JWT_ACCESS_SECRET=replace-with-cryptographically-random-string-min-32-chars

# Secret for signing refresh JWTs (min 32 random chars, different from access)
JWT_REFRESH_SECRET=replace-with-another-cryptographically-random-string

# Access token lifetime (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES=15m

# Refresh token lifetime (e.g. 7d)
JWT_REFRESH_EXPIRES=7d

# Comma-separated browser origins allowed to call this API with credentials
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# HTTP port the API listens on
PORT=4000

# development | production
NODE_ENV=development
